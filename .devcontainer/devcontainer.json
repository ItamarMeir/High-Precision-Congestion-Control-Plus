{
  "name": "HPCC Simulator",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "runArgs": [
    "-e",
    "DISPLAY=${localEnv:DISPLAY}",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix:rw"
  ],
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "python.pythonPath": "/usr/bin/python" 
      },
      "extensions": [
        "ms-vscode.cpptools"
      ]
    }
  }
}